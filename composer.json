{
  "name": "tradecentric/module-purchase-order",
  "description": "TradeCentric Purchase Order",
  "type": "magento2-module",
    "license": [
    "OSL-3.0",
    "AFL-3.0"
  ],
  "version": "3.0.14",
  "require": {
    "php": "^7.0||^8.0",
    "tradecentric/module-version": "*",
    "tradecentric/module-punchout": "*"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "magento/magento-coding-standard": "*",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "cs": "php -d auto_prepend_file=phpcs-bootstrap.php vendor/bin/phpcs --standard=phpcs.xml.dist",
    "cs:fixable": "php -d auto_prepend_file=phpcs-bootstrap.php vendor/bin/phpcbf --standard=phpcs.xml.dist"
  },
  "suggest": {
	  
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Punchout2Go\\PurchaseOrder\\": ""
    }
  }
}
